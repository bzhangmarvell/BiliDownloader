{
  "name": "bilidownloader",
  "version": "1.1.0",
  "description": "哔哩哔哩视频下载器 - Bilibili Video Downloader",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:main && npm run build:renderer && electron-builder",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "release": "echo 'Manual release - update version in package.json'",
    "electron:dev": "vite",
    "electron:build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "author": "OpenClaw",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.0.0",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "fluent-ffmpeg": "^2.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/crypto-js": "^4.2.0",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/node": "^22.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.openclaw.bilidownloader",
    "productName": "BiliDownloader",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*"
    ],
    "asarUnpack": [
      "resources/ffmpeg/**/*"
    ],
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}
